# ============================================================
# KETER MARKETING — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement local
# Configurez ces variables dans le dashboard Vercel en production
# ============================================================

# --- Envoi d'emails (formulaire de contact) ---
# Créer un compte sur https://resend.com et générer une clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de destination pour les demandes de contact
CONTACT_EMAIL=contact.ketermarketing@gmail.com
NEXT_PUBLIC_SITE_URL=https://ketermarketing.com

# Domaine vérifié sur Resend pour l'expéditeur
RESEND_FROM_EMAIL=noreply@ketermarketing.com

# --- Google Analytics 4 ---
# Mesurement ID depuis https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Calendly ---
# URL de votre page Calendly (sans le https://)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/ketermarketing/30min

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://ketermarketing.com
